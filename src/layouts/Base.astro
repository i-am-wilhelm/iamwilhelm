---
import '../styles/global.css';
import MuteToggle from '../components/MuteToggle.astro';

interface Props {
  title: string;
  description?: string;
  /** Pages outside the initiation (underworld) opt out of indexing. */
  noindex?: boolean;
}

const {
  title,
  description = 'Michael Wilhelm. Builder. Writer. Musician.',
  noindex = false,
} = Astro.props;
---

<!doctype html>
<html lang="en" data-phase="nigredo">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#050505" />
    <title>{title}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <script>
      document.documentElement.classList.add('js');
    </script>
  </head>
  <body>
    <slot />
    <MuteToggle />
    <script>
      import { initGreatFade } from '../lib/fade';
      import { initReveals } from '../lib/timing';
      import { initEggs } from '../lib/eggs-wiring';
      import { isMuted, wake } from '../lib/audio/engine';

      initGreatFade();
      initReveals();
      initEggs();

      // Audio re-entry: the AudioContext dies with each page navigation,
      // and autoplay policy demands a fresh gesture. If the visitor
      // already crossed the threshold with sound ('wilhelm.entered' is
      // set by ThresholdGate), the first interaction on any page quietly
      // wakes the engine again.
      let entered = false;
      try {
        entered = sessionStorage.getItem('wilhelm.entered') === '1';
      } catch {}
      if (entered && !isMuted()) {
        const resume = () => {
          void wake();
          window.removeEventListener('pointerdown', resume);
          window.removeEventListener('keydown', resume);
        };
        window.addEventListener('pointerdown', resume, { once: true });
        window.addEventListener('keydown', resume, { once: true });
      }
    </script>
  </body>
</html>
