---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Michael Wilhelm — personal site.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <!-- Shared WebGL stage: dither, smoke, and morph passes composite here. -->
    <canvas id="gl-stage" aria-hidden="true"></canvas>
    <main>
      <slot />
    </main>
    <script>
      import { boot } from '../scripts/boot';
      boot();
    </script>
  </body>
</html>
