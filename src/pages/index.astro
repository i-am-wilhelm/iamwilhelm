---
import Base from '../layouts/Base.astro';
import ThresholdGate from '../components/ThresholdGate.astro';
import DitherCanvas from '../components/DitherCanvas.astro';
import Constellation from '../components/Constellation.astro';
import Marginalia from '../components/Marginalia.astro';
import Footer from '../components/Footer.astro';
import { getWritings } from '../lib/content';

const writings = (await getWritings()).slice(0, 3);

const dateFmt = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Base title="Michael Wilhelm — iamwilhelm.com">
  <ThresholdGate />

  <!-- ═══ Hero — the Black Swan ═══ -->
  <section class="section hero" id="hero" style="--accent: var(--smoke-swan);">
    <div class="hero-art">
      <DitherCanvas
        src="/img/placeholder-swan.svg"
        palette="ascii"
        mode="resolve"
        cell={11}
        seed={7}
        accent="var(--smoke-swan)"
        ratio="16 / 10"
        label="The Black Swan — a form suggested more than shown, brilliant and terrifying"
      />
    </div>
    <div class="section-inner hero-card">
      <div class="hero-face">
        <DitherCanvas
          src="/img/facecard.jpg"
          palette="ascii"
          mode="resolve"
          cell={7}
          seed={3}
          accent="var(--smoke-swan)"
          ratio="1 / 1"
          label="Michael Wilhelm — portrait resolving out of glyphs"
        />
      </div>
      <div class="hero-bio">
        <p class="term reveal">&gt; Michael Wilhelm</p>
        <h1 class="hero-title reveal">Builder. Writer. Reader of symbols.</h1>
        <p class="hero-lede reveal">
          There is a world beneath the one you were handed. This is where I map it.
        </p>
        <Marginalia text="The Fumigation from Storax." />
      </div>
    </div>
  </section>

  <!-- ═══ Constellation Sky ═══ -->
  <section class="section sky-section" id="sky" style="--accent: var(--smoke-sky);">
    <div class="section-inner">
      <Marginalia text="The Fumigation from Frankincense." />
    </div>
    <Constellation />
  </section>

  <!-- ═══ Writings preview — Medea / Pharmakon ═══ -->
  <section class="section" id="writings" style="--accent: var(--smoke-medea);">
    <div class="section-inner">
      <p class="term reveal">&gt; writings</p>
      <ul class="writing-list" role="list">
        {
          writings.map((w) => (
            <li class="reveal">
              <a href={`/writings/${w.slug}/`} style={`--accent: ${w.accent};`}>
                <span class="writing-glyph" aria-hidden="true">
                  {w.symbol.glyph}
                </span>
                <span class="writing-title">{w.title}</span>
                <time class="writing-date" datetime={w.date.toISOString()}>
                  {dateFmt.format(w.date)}
                </time>
              </a>
            </li>
          ))
        }
      </ul>
      <p class="reveal"><a class="term" href="/writings/">all writings →</a></p>
      <Marginalia text="The Fumigation from Myrrh." />
    </div>
  </section>

  <!-- ═══ Philosophy — Columbia / Pallas ═══ -->
  <section class="section" id="philosophy" style="--accent: var(--smoke-pallas);">
    <div class="section-inner">
      <p class="term reveal">&gt; philosophy</p>
      <!--
        TODO(phase-2): Atlas bearing the sphere morphing into Columbia
        raising the torch / Pallas with spear. Placeholder abstract below.
      -->
      <DitherCanvas
        src="/img/placeholder-atlas.svg"
        palette="greek"
        mode="resolve"
        cell={12}
        seed={23}
        accent="var(--smoke-pallas)"
        ratio="16 / 9"
        label="Atlas bearing the sphere — placeholder"
      />
      <p class="reveal">
        <!-- TODO(copy): philosophy section copy from Michael -->
        The weight held first. The torch raised after.
      </p>
      <Marginalia text="The Fumigation from Aromatics." />
    </div>
  </section>

  <!-- ═══ Memoir — the Monsoon ═══ -->
  <section class="section monsoon" id="memoir" style="--accent: var(--smoke-monsoon);">
    <div class="section-inner">
      <p class="term reveal">&gt; memoir</p>
      <!--
        TODO(phase-3): the monsoon system — three states across this
        section's scroll: drought (sparse, heat-shimmer, bone/rust) →
        the break (Greek glyph rain, single-frame chromatic lightning,
        sub-bass thunder) → release (dense dither cooling to PNW
        greens/grays). Phase 1 holds the drought still.
        TODO(phase-4): Open-Meteo live-weather flag — real rain in
        Phoenix runs the rain state site-wide, subtly.
      -->
      <DitherCanvas
        src="/img/placeholder-monsoon.svg"
        palette="greek"
        mode="static"
        cell={14}
        seed={41}
        accent="var(--smoke-monsoon)"
        ratio="16 / 8"
        label="Drought — sparse glyphs over cracked ground, waiting for the break"
      />
      <p class="reveal">
        <!-- TODO(copy): memoir excerpt from Michael -->
        The desert taught me to wait. The rain taught me what waiting was for.
      </p>
      <Marginalia text="The Fumigation from Torches." />
    </div>
  </section>

  <!-- ═══ Dawn close — Venus as morning star ═══ -->
  <section class="section dawn" id="dawn" style="--accent: var(--smoke-venus);">
    <div class="section-inner dawn-inner">
      <div class="dawn-star">
        <DitherCanvas
          palette="ascii"
          mode="static"
          variant="stars"
          cell={8}
          seed={2}
          accent="var(--smoke-venus)"
          ratio="1 / 1"
          label="One held star — Venus, rising last"
        />
      </div>
      <p class="term reveal">
        <!-- TODO(copy): confirm contact address -->
        &gt; michael@iamwilhelm.com
      </p>
      <Marginalia text="The Fumigation from Manna." />
    </div>
    <Footer />
  </section>
</Base>

<style>
  .hero {
    min-height: 100vh;
    padding-top: 20vh;
  }
  .hero-art {
    width: min(100%, 780px);
    margin-bottom: var(--space-3);
  }
  .hero-card {
    display: grid;
    grid-template-columns: minmax(160px, 240px) 1fr;
    gap: var(--space-3);
    align-items: center;
    max-width: 56rem;
  }
  @media (max-width: 640px) {
    .hero-card {
      grid-template-columns: 1fr;
    }
    .hero-face {
      max-width: 240px;
    }
  }
  .hero-title {
    font-size: var(--text-2xl);
    letter-spacing: 0.01em;
  }
  .hero-lede {
    font-size: var(--text-lg);
    color: var(--ink-dim);
    max-width: 38ch;
  }

  .sky-section {
    padding-inline: 0;
  }
  .sky-section .section-inner {
    padding-inline: var(--space-3);
  }

  .writing-list {
    margin: 0 0 var(--space-3);
    padding: 0;
    list-style: none;
  }
  .writing-list a {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: baseline;
    gap: var(--space-2);
    padding: var(--space-2) 0;
    border-bottom: 1px solid var(--hairline);
    text-decoration: none;
  }
  .writing-list a:hover .writing-title {
    color: var(--accent);
  }
  .writing-glyph {
    color: var(--accent);
    font-size: var(--text-lg);
  }
  .writing-title {
    font-size: var(--text-lg);
    transition: color var(--pulse-2) var(--ease-veil);
  }
  .writing-date {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--ink-dim);
  }

  .dawn {
    min-height: 90vh;
    justify-content: flex-end;
  }
  .dawn-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .dawn-star {
    width: min(30vmin, 180px);
    margin-bottom: var(--space-3);
  }
</style>
