---
/**
 * The Underworld — Phase 3. Hidden route; no nav links anywhere.
 * Entered only via the golden bough (egg 7) hidden in the homepage's
 * philosophy field.
 *
 * The descent: Threshold → River/Toll → Reading of Marks → the
 * Weighing → Fields of Mourning → the Return → the exit. Markup and
 * canonical copy live in UnderworldStations.astro; scroll logic, the
 * audio contract (underworld:depth, underworld:presence, audio:pluck),
 * and the Orpheus rule live in lib/underworld.ts.
 *
 * The Great Fade does not reach here — the underworld never lightens.
 * Rather than touching fade.ts or Base.astro, this page shadows the
 * :root fade variables locally and holds a fixed black backdrop under
 * the content: permanent nigredo.
 */
import Base from '../../layouts/Base.astro';
import UnderworldStations from '../../components/UnderworldStations.astro';
---

<Base title="•" noindex>
  <main class="descent">
    <UnderworldStations />
  </main>
</Base>

<style>
  .descent {
    position: relative;
    /* shadow the :root fade vars — the underworld never lightens */
    --bg: #000;
    --ink: #e8e6e1;
    --ink-dim: rgba(232, 230, 225, 0.55);
    --accent: var(--smoke-pallas);
    color: var(--ink);
  }
  /* fixed backdrop beneath the content, whatever the fade does to body */
  .descent::before {
    content: '';
    position: fixed;
    inset: 0;
    z-index: -1;
    background: #000;
  }
</style>

<script>
  import { initUnderworld } from '../../lib/underworld';
  initUnderworld();
</script>
