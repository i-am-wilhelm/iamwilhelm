---
/**
 * The Underworld — Phase 3. Hidden route; no nav links anywhere.
 * Entered only via the golden bough hidden in a homepage dither field.
 *
 * TODO(phase-3): the descent —
 *   Threshold → River/Toll → Reading of Marks (the Furies; greed stains
 *   deepest) → the Weighing (heart vs. feather) → Fields of Mourning →
 *   the Return. Second-person epigraphic fragments surface from the
 *   dither. Drones pitch downward with depth; binaural water; held
 *   dissonance at the Furies.
 *
 * The Orpheus rule: at the Return, one instruction — climb without
 * turning back. Scrolling upward before the exit dissolves the reward
 * fragment and a presence leaves the audio mix. Forward completion
 * grants a passphrase fragment.
 */
import Base from '../../layouts/Base.astro';
---

<Base title="•" noindex>
  <main class="descent">
    <p class="fragment">You arrive wearing everything you did.</p>
    <!-- The rest of the stations are dug in Phase 3. -->
  </main>
</Base>

<style>
  .descent {
    min-height: 100vh;
    display: grid;
    place-items: center;
    background: #000;
  }
  .fragment {
    font-style: italic;
    letter-spacing: var(--tracking-wide);
    color: rgba(232, 230, 225, 0.6);
    padding: var(--space-3);
    text-align: center;
  }
</style>
