---
import Base from '../layouts/Base.astro';
---

<Base title="Lost — I Am Wilhelm">
  <section class="section">
    <div class="copy">
      <h2 class="greek">οὐκ ἔστιν ὧδε</h2>
      <p>This path leads nowhere. <a href="/" style="color: var(--ink)">Return to the surface.</a></p>
      <!-- The psychopomp's door: bound only after the hunt reaches
           awaiting-seal, and ships disabled (see eggs.config.ts). -->
      <span data-egg-anchor="psychopomp-door" class="greek" aria-hidden="true"
        style="position: absolute; bottom: -20vh; opacity: 0.18;">Δ</span>
    </div>
  </section>
</Base>
