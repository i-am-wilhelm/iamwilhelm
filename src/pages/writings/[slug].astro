---
import Base from '../../layouts/Base.astro';
import DitherCanvas from '../../components/DitherCanvas.astro';
import Footer from '../../components/Footer.astro';
import { getWritings, renderWriting } from '../../lib/content';

export async function getStaticPaths() {
  const writings = await getWritings();
  return writings.map((w) => ({ params: { slug: w.slug }, props: { writing: w } }));
}

const { writing } = Astro.props;
const { Content } = await renderWriting(writing);

const dateFmt = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Base title={`${writing.title} — Michael Wilhelm`} description={writing.description}>
  <article class="post" style={`--accent: ${writing.accent};`}>
    <header class="post-header">
      <!--
        The governing symbol's constellation heads the page.
        TODO(phase-2): swap the placeholder abstract for the symbol's
        true constellation render.
      -->
      <DitherCanvas
        palette="greek"
        mode="resolve"
        cell={11}
        seed={writing.symbol.seed}
        accent={writing.accent}
        ratio="21 / 9"
        label={`${writing.symbol.name} — the governing symbol of this writing`}
      />
      <div class="post-meta section-inner">
        <p class="term">
          <a href="/writings/">&lt; writings</a>
          <span class="post-symbol" aria-hidden="true">{writing.symbol.glyph}</span>
        </p>
        <h1>{writing.title}</h1>
        <p class="post-desc">{writing.description}</p>
        <time datetime={writing.date.toISOString()}>{dateFmt.format(writing.date)}</time>
        <span class="ornament" aria-hidden="true">§</span>
      </div>
    </header>
    <div class="post-body section-inner">
      <Content />
    </div>
  </article>
  <Footer />
</Base>

<style>
  .post {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .post-header {
    width: 100%;
  }
  .post-meta {
    padding: var(--space-3);
    position: relative;
  }
  .post-symbol {
    color: var(--accent);
    margin-left: var(--space-2);
  }
  .post-desc {
    color: var(--ink-dim);
    font-style: italic;
  }
  .post-meta time {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--ink-dim);
  }
  .ornament {
    position: absolute;
    right: var(--space-3);
    bottom: var(--space-3);
    display: inline-block;
    color: var(--accent);
    opacity: 0.5;
    transform: rotate(23.52deg); /* — 8th house */
  }
  .post-body {
    padding: var(--space-3);
    padding-bottom: var(--space-4);
  }
  .post-body :global(h2) {
    margin-top: var(--space-3);
    color: var(--accent);
    font-size: var(--text-xl);
  }
  .post-body :global(blockquote) {
    margin: var(--space-3) 0;
    padding-left: var(--space-2);
    border-left: 2px solid var(--accent);
    color: var(--ink-dim);
    font-style: italic;
  }
  .post-body :global(em) {
    letter-spacing: 0.02em;
  }
</style>
