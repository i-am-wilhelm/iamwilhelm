---
/**
 * UnderworldStations — the seven stations of the descent (Phase 3).
 *
 * Each station is one second-person epigraphic fragment beneath a
 * greek-palette dither field; sentences light in 2+2+3 order through
 * the global reveal system. Fragments are real DOM text — only the
 * canvases are decorative.
 *
 * The exit (station 7) always renders its dither, but the reward —
 * fragment and inscription — stays out of the visible and accessible
 * tree until lib/underworld.ts rules on the climb: `is-open` grants it,
 * `is-lost` veils the field for the rest of the descent.
 *
 * Copy is canonical (spec §7) — do not edit the fragments.
 */
import DitherCanvas from './DitherCanvas.astro';
import { PASSPHRASE } from '../lib/underworld';

interface Station {
  n: number;
  seed: number;
  /** Sentences of the fragment; each lights on its own beat. */
  lines: string[];
}

const STATIONS: Station[] = [
  { n: 1, seed: 61, lines: ['You arrive wearing everything you did.'] },
  { n: 2, seed: 67, lines: ['The ferryman counts what you carried, and how tightly.'] },
  {
    n: 3,
    seed: 71,
    lines: ['Here they read the marks.', 'Greed goes deepest — it stains through.'],
  },
  {
    n: 4,
    seed: 73,
    lines: ['Your heart on one pan.', 'A feather on the other.', 'The scale is honest.'],
  },
  {
    n: 5,
    seed: 79,
    lines: ['The fields hold everyone love consumed.', 'Walk quietly here.'],
  },
  { n: 6, seed: 83, lines: ['Climb without turning back.'] },
];

/** The dim ash the stations glow in; the exit alone burns pallas gold. */
const ASH = '#8c8880';
---

{
  STATIONS.map((s) => (
    <section class:list={['station', { return: s.n === 6 }]} data-station={s.n}>
      <div class="station-art">
        <DitherCanvas
          palette="greek"
          mode="resolve"
          cell={13}
          seed={s.seed}
          accent={ASH}
          ratio="16 / 9"
        />
      </div>
      <p class="fragment">
        {s.lines.map((line) => (
          <span class="line reveal">{line}</span>
        ))}
      </p>
    </section>
  ))
}

<section class="station exit" data-station="7">
  <div class="station-art">
    <DitherCanvas
      palette="greek"
      mode="resolve"
      cell={13}
      seed={89}
      accent="var(--smoke-pallas)"
      ratio="16 / 9"
    />
  </div>
  <div class="exit-reward">
    <p class="fragment"><span class="line">Speak, if you learned the words.</span></p>
    <p class="inscription" lang="grc">{PASSPHRASE}</p>
  </div>
</section>

<style>
  .station {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-3);
  }
  .station-art {
    width: min(100%, 620px);
  }
  .fragment {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4em;
    text-align: center;
    font-style: italic;
    font-size: var(--text-lg);
    letter-spacing: var(--tracking-wide);
    color: rgba(232, 230, 225, 0.68);
    max-width: 34ch;
  }

  /* the Return: one instruction, then a long silent stretch to climb */
  .return {
    min-height: 175vh;
    justify-content: flex-start;
    padding-top: 30vh;
  }

  .exit-reward {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    visibility: hidden;
    opacity: 0;
    transition: opacity var(--bar-7-8) var(--ease-veil);
  }
  .exit.is-open .exit-reward {
    visibility: visible;
    opacity: 1;
  }
  /* betrayal veil for an exit engine already woken (see underworld.ts) */
  .exit.is-lost :global(glyph-dither) {
    opacity: 0.22;
    transition: opacity var(--bar-7-8) var(--ease-veil);
  }
  .inscription {
    margin: 0;
    font-size: var(--text-xl);
    letter-spacing: 0.5em;
    padding-inline-start: 0.5em; /* recenter the tracked capitals */
    color: var(--smoke-pallas);
  }
</style>
