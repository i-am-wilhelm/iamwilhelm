---
/**
 * SCROLL CLUSTER — dither-star cluster resolving into constellation-like
 * symbols fading into 3D (spec §4.2). The shader does the visual work; this
 * layer stays almost silent — sparse, evocative copy only.
 */
import Section from '../Section.astro';
import type { SectionSpec } from '../../design/tokens';

interface Props {
  spec: SectionSpec;
}

const { spec } = Astro.props;
---

<Section spec={spec}>
  <p class="line">The stars were letters first.</p>
  <p class="line line--dim greek">Πλειάδες — seven, and the eye finds six.</p>
</Section>

<style>
  .line {
    font-size: clamp(1.1rem, 2.6vw, 1.6rem);
    letter-spacing: 0.05em;
    color: var(--ink);
    margin-bottom: 0.8rem;
  }

  .line--dim {
    font-size: clamp(0.9rem, 2vw, 1.15rem);
    color: var(--ink-dim);
  }
</style>
