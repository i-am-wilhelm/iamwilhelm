---
/**
 * Footer — the colophon and, hidden, the entrance seed for the underworld.
 *
 * The colophon reads α´ Μαρτίου ͵αϡϟα — a date written in Greek
 * alphabetic numerals that requires the dead letters to exist at all
 * (egg #4). Styled as ornament; those who can read it, can read it.
 */
---

<footer class="site-footer">
  <p class="colophon" aria-hidden="true">α´ Μαρτίου ͵αϡϟα</p>
  <p class="footer-line term">
    <!-- TODO(copy): real contact line from Michael -->
    <a href="/writings/">writings</a>
  </p>
  <!--
    TODO(phase-3): the golden bough hides here — a small branch glyph
    inside one homepage dither field opens the descent to /underworld.
    data-seed below is the registry hook, not the door itself.
  -->
  <span data-seed="χρύσεον-κλάδον" hidden></span>
</footer>

<style>
  .site-footer {
    padding: var(--space-4) var(--space-3);
    text-align: center;
  }
  .colophon {
    font-size: var(--text-xs);
    letter-spacing: 0.3em;
    color: var(--ink-dim);
    margin-bottom: var(--space-2);
  }
  .footer-line {
    font-size: var(--text-xs);
  }
</style>
