---
/**
 * <Constellation> — Phase 2: the constellation sky.
 *
 * A field of dither-stars (the <DitherCanvas variant="stars"> back layer)
 * over which the twelve symbol-constellations resolve as they enter the
 * viewport — stars bloom, then lines draw in, staggered on the 2+2+3
 * grid. Three canvas layers translate at different rates with scroll
 * (plus a whisper of pointer drift) for depth; real 3D waits for later.
 *
 * Systems in here:
 *   - Cross → Black Cube: the Cross's stars are an unfolded cube net;
 *     scroll folds the six faces about their hinges into a void-black
 *     cube (2.5D projection). Reduced motion shows the cube folded.
 *   - Thoth → Hermes: Hermes first stands as Thoth with the Was-scepter,
 *     morphing to the caduceus with scroll/hover; the superimposed
 *     midpoint lingers (lingerEase plateaus at 0.5).
 *   - Eggs 1–3 (see eggs.ts): Mercury cazimi at Sol Niger's empty
 *     center, Saturn met at the MC, the grand trine walked in one visit.
 *
 * Every constellation is a real <a> overlay (Medea → /writings/pharmakon/,
 * the rest → /writings/ for now). rAF pauses offscreen and when the
 * document hides; reduced motion renders one fully-resolved still.
 */
import DitherCanvas from './DitherCanvas.astro';
import { CONSTELLATIONS } from '../lib/constellations';

const DEPTHS = [0, 1, 2] as const;
const byDepth = DEPTHS.map((d) => CONSTELLATIONS.filter((c) => c.depth === d));
const solNiger = CONSTELLATIONS.find((c) => c.id === 'solniger')!;
---

<constellation-sky>
  <DitherCanvas
    palette="greek"
    mode="static"
    variant="stars"
    cell={11}
    seed={12}
    accent="var(--smoke-sky)"
    ratio="auto"
    class="sky-field"
    label="A sky of glyph-stars"
  />
  {
    DEPTHS.map((d) => (
      <div class="sky-layer" data-depth={d}>
        <canvas aria-hidden="true" />
        {byDepth[d]!.map((c) => (
          <a
            class="sky-node"
            href={c.href}
            data-id={c.id}
            style={`left:${c.cx}%; top:${c.cy}%;`}
            aria-label={`${c.name} — constellation`}
            title={c.name}
          />
        ))}
        {d === 1 && (
          <button
            class="cazimi"
            type="button"
            style={`left:${solNiger.cx}%; top:${solNiger.cy}%;`}
            aria-label="Mercury, in the heart of the black sun"
          >
            ☿
          </button>
        )}
      </div>
    ))
  }
</constellation-sky>

<style>
  /* the sky owns its own height; the section supplies no padding */
  constellation-sky {
    display: block;
    position: relative;
    width: 100%;
    height: min(120vh, 900px);
    overflow: hidden;
  }
  constellation-sky :global(.sky-field) {
    position: absolute;
    inset: 0;
    height: 100%;
  }
  .sky-layer {
    position: absolute;
    inset: 0;
    pointer-events: none;
    will-change: transform;
  }
  .sky-layer canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .sky-node {
    position: absolute;
    transform: translate(-50%, -50%);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    pointer-events: auto;
  }
  .sky-node:focus-visible {
    outline: 1px solid var(--smoke-sky);
    outline-offset: 4px;
  }
  .cazimi {
    position: absolute;
    transform: translate(-50%, -50%);
    display: grid;
    place-items: center;
    width: 34px;
    height: 34px;
    padding: 0;
    border: 0;
    background: none;
    color: var(--smoke-sky);
    font-size: 1.05rem;
    line-height: 1;
    opacity: 0;
    pointer-events: auto;
    cursor: pointer;
    z-index: 2;
    transition: opacity var(--pulse-2) var(--ease-veil);
  }
  .cazimi:hover,
  .cazimi:focus-visible,
  .cazimi:active,
  .cazimi.lit {
    opacity: 1;
    text-shadow: 0 0 10px currentColor;
  }
  @media (prefers-reduced-motion: reduce) {
    .cazimi {
      transition: none;
    }
  }
</style>

<script>
  import {
    CONSTELLATIONS,
    foldCrossNet,
    lingerEase,
    THOTH_FORM,
    TRINE_IDS,
    type ConLine,
    type ConstellationDef,
  } from '../lib/constellations';
  import { BAR, PULSE, staggerDelays } from '../lib/timing';
  import { mark } from '../lib/eggs';

  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const finePointer = window.matchMedia('(pointer: fine)').matches;

  const DPR_CAP = 1.5;
  const TAU = Math.PI * 2;
  const STAR_FADE = PULSE * 3; // one long beat per star bloom
  const LINE_START = BAR; // lines begin a bar after the stars
  /** Layer translate per px of scroll delta: far drags, near leads. */
  const PARALLAX = [0.055, 0.02, -0.035] as const;
  const DRIFT_SCALE = [0.35, 0.65, 1] as const;
  const DRIFT_MAX = 7; // px of pointer drift on the near layer
  const TRINE_KEY = 'wilhelm.trine';

  function clamp01(v: number): number {
    return v < 0 ? 0 : v > 1 ? 1 : v;
  }

  function parseHex(value: string): [number, number, number] {
    const m = /^#([0-9a-f]{3}|[0-9a-f]{6})$/i.exec(value.trim());
    if (!m) return [201, 205, 214]; // --smoke-sky fallback
    let h = m[1]!;
    if (h.length === 3) h = h.replace(/./g, (c) => c + c);
    return [
      parseInt(h.slice(0, 2), 16),
      parseInt(h.slice(2, 4), 16),
      parseInt(h.slice(4, 6), 16),
    ];
  }

  interface Cluster {
    def: ConstellationDef;
    /** Star positions in CSS px for the current sky size. */
    px: Float32Array;
    starDelays: number[];
    lineDelays: number[];
    /** T past this ⇒ fully resolved (fast line path). */
    resolvedAt: number;
    /** performance.now() the cluster's reveal began; Infinity = waiting. */
    revealAt: number;
    hi: number;
    hiTarget: number;
  }

  class ConstellationSky extends HTMLElement {
    private layerEls: HTMLDivElement[] = [];
    private canvases: HTMLCanvasElement[] = [];
    private ctxs: CanvasRenderingContext2D[] = [];
    private clusters: Cluster[] = [];
    private anchors: Array<[HTMLAnchorElement, number]> = [];
    private crossIdx = -1;
    private hermesIdx = -1;

    private w = 0;
    private h = 0;
    private dpr = 1;
    private accentStyle = 'rgb(201,205,214)';
    private voidStyle = 'rgb(5,5,5)';

    private running = false;
    private visible = false;
    private rafId = 0;
    private dirty = true;
    private tick = 0;

    private waveCount = 0;
    private waveDelays = staggerDelays(CONSTELLATIONS.length);

    private foldT = 0;
    private morphScroll = 0;
    private morphCur = 0;
    private hermesHover = false;
    private parY: [number, number, number] = [0, 0, 0];
    private driftX = 0;
    private driftY = 0;

    // scratch buffers — no per-frame allocation
    private crossBuf = new Float32Array(6 * 4 * 3);
    private crossProj = new Float32Array(6 * 4 * 2);
    private crossZ = new Float32Array(6);
    private crossOrder = [0, 1, 2, 3, 4, 5];
    private thothPx = new Float32Array(THOTH_FORM.stars.length * 2);
    private hermesPx = new Float32Array(THOTH_FORM.stars.length * 2);
    private lastFoldDrawn = -1;
    private lastMorphDrawn = -1;

    private io?: IntersectionObserver;
    private ro?: ResizeObserver;
    private onScrollBound = () => this.onScroll();
    private onVisibility = () => this.syncRunning();
    private onPointerMove = (e: PointerEvent) => {
      this.driftX = -((e.clientX / window.innerWidth) * 2 - 1) * DRIFT_MAX;
      this.driftY = -((e.clientY / window.innerHeight) * 2 - 1) * (DRIFT_MAX * 0.6);
      this.applyTransforms();
    };

    connectedCallback() {
      // lazy-init as the sky approaches the fold
      const wake = new IntersectionObserver(
        (entries) => {
          if (entries.some((e) => e.isIntersecting)) {
            wake.disconnect();
            this.init();
          }
        },
        { rootMargin: '300px 0px' }
      );
      wake.observe(this);
    }

    private init(): void {
      this.layerEls = Array.from(this.querySelectorAll<HTMLDivElement>('.sky-layer'));
      this.canvases = this.layerEls.map((l) => l.querySelector('canvas')!);
      this.ctxs = this.canvases.map((c) => c.getContext('2d')!);

      const cs = getComputedStyle(this);
      const [ar, ag, ab] = parseHex(cs.getPropertyValue('--smoke-sky'));
      const [vr, vg, vb] = parseHex(cs.getPropertyValue('--void'));
      this.accentStyle = `rgb(${ar},${ag},${ab})`;
      this.voidStyle = `rgb(${vr},${vg},${vb})`;

      this.clusters = CONSTELLATIONS.map((def) => {
        // the cross reveals per face-corner (24 marks) on a tighter grid
        const starCount = def.id === 'cross' ? 24 : def.stars.length;
        const starPulse = def.id === 'cross' ? PULSE / 4 : PULSE / 2;
        const lineDelays = staggerDelays(def.lines.length, PULSE / 2);
        return {
          def,
          px: new Float32Array(def.stars.length * 2),
          starDelays: staggerDelays(starCount, starPulse),
          lineDelays,
          resolvedAt: LINE_START + (lineDelays[lineDelays.length - 1] ?? 0) + STAR_FADE,
          revealAt: reducedMotion ? 0 : Infinity,
          hi: 0,
          hiTarget: 0,
        };
      });
      this.crossIdx = CONSTELLATIONS.findIndex((c) => c.id === 'cross');
      this.hermesIdx = CONSTELLATIONS.findIndex((c) => c.id === 'hermes');

      this.wireOverlays();

      this.ro = new ResizeObserver(() => this.resize());
      this.ro.observe(this);
      this.resize();

      this.io = new IntersectionObserver(
        (entries) => {
          this.visible = entries.some((e) => e.isIntersecting);
          this.syncRunning();
        },
        { threshold: 0 }
      );
      this.io.observe(this);
      document.addEventListener('visibilitychange', this.onVisibility);

      if (!reducedMotion) {
        window.addEventListener('scroll', this.onScrollBound, { passive: true });
        if (finePointer) this.addEventListener('pointermove', this.onPointerMove);
        this.onScroll(); // seed reveals + parallax for whatever's on screen
      }
    }

    /* -- overlays: links, eggs ----------------------------------- */

    private wireOverlays(): void {
      for (const a of this.querySelectorAll<HTMLAnchorElement>('a.sky-node')) {
        const id = a.dataset.id ?? '';
        const idx = this.clusters.findIndex((c) => c.def.id === id);
        if (idx < 0) continue;
        this.anchors.push([a, idx]);
        const cluster = this.clusters[idx]!;

        const on = () => {
          cluster.hiTarget = 1;
          if (id === 'hermes') this.hermesHover = true;
          if (reducedMotion) cluster.hi = 1;
          this.dirty = true;
          if (!this.running) this.paint(performance.now());
        };
        const off = () => {
          cluster.hiTarget = 0;
          if (id === 'hermes') this.hermesHover = false;
          if (reducedMotion) cluster.hi = 0;
          this.dirty = true;
          if (!this.running) this.paint(performance.now());
        };
        a.addEventListener('pointerenter', on);
        a.addEventListener('pointerleave', off);
        a.addEventListener('focus', on);
        a.addEventListener('blur', off);

        if (id === 'saturn') {
          // egg #2 — Saturn met while it culminates at the top of the view
          const atMC = () => {
            const r = a.getBoundingClientRect();
            if (r.top >= 0 && r.top < window.innerHeight * 0.28) mark('saturn-mc');
          };
          a.addEventListener('pointerenter', atMC);
          a.addEventListener('click', atMC);
        }

        if ((TRINE_IDS as readonly string[]).includes(id)) {
          a.addEventListener('click', () => this.recordTrine(id));
        }
      }

      // egg #1 — Mercury cazimi, at Sol Niger's empty center
      const cazimi = this.querySelector<HTMLButtonElement>('.cazimi');
      cazimi?.addEventListener('click', () => {
        mark('mercury-cazimi');
        cazimi.classList.add('lit');
      });
    }

    /** Egg #3 — the trine's vertices, all three clicked in one visit. */
    private recordTrine(id: string): void {
      try {
        const found = new Set<string>(
          JSON.parse(sessionStorage.getItem(TRINE_KEY) ?? '[]') as string[]
        );
        found.add(id);
        sessionStorage.setItem(TRINE_KEY, JSON.stringify([...found]));
        if (TRINE_IDS.every((t) => found.has(t))) mark('grand-trine');
      } catch {
        /* no session storage — the triangle must be walked elsewhere */
      }
    }

    /* -- geometry ------------------------------------------------- */

    private resize(): void {
      const rect = this.getBoundingClientRect();
      if (rect.width === 0 || rect.height === 0) return;
      this.w = rect.width;
      this.h = rect.height;
      this.dpr = Math.min(window.devicePixelRatio || 1, DPR_CAP);
      for (const cv of this.canvases) {
        cv.width = Math.round(this.w * this.dpr);
        cv.height = Math.round(this.h * this.dpr);
      }
      const minDim = Math.min(this.w, this.h);
      for (const c of this.clusters) {
        const box = c.def.scale * minDim;
        const cx = (c.def.cx / 100) * this.w;
        const cy = (c.def.cy / 100) * this.h;
        const stars = c.def.stars;
        for (let j = 0; j < stars.length; j++) {
          c.px[j * 2] = cx + (stars[j]!.x - 0.5) * box;
          c.px[j * 2 + 1] = cy + (stars[j]!.y - 0.5) * box;
        }
      }
      // Thoth shares Hermes' box for the 1:1 morph
      const hc = this.clusters[this.hermesIdx]!;
      const hbox = hc.def.scale * minDim;
      const hx = (hc.def.cx / 100) * this.w;
      const hy = (hc.def.cy / 100) * this.h;
      for (let j = 0; j < THOTH_FORM.stars.length; j++) {
        this.thothPx[j * 2] = hx + (THOTH_FORM.stars[j]!.x - 0.5) * hbox;
        this.thothPx[j * 2 + 1] = hy + (THOTH_FORM.stars[j]!.y - 0.5) * hbox;
      }
      // hit areas track their clusters
      for (const [a, idx] of this.anchors) {
        const size = Math.max(44, Math.round(this.clusters[idx]!.def.scale * minDim * 0.85));
        a.style.width = `${size}px`;
        a.style.height = `${size}px`;
      }
      this.lastFoldDrawn = -1;
      this.lastMorphDrawn = -1;
      this.dirty = true;
      if (!this.running) this.paint(performance.now());
    }

    private onScroll(): void {
      if (this.w === 0) return;
      const rect = this.getBoundingClientRect();
      const vh = window.innerHeight;
      const now = performance.now();

      // clusters resolve as their band crosses the fold, on the 2+2+3 wave
      if (this.waveCount < this.clusters.length) {
        for (const c of this.clusters) {
          if (c.revealAt !== Infinity) continue;
          const sy = rect.top + (c.def.cy / 100) * rect.height;
          if (sy < vh * 0.96) {
            c.revealAt = now + (this.waveDelays[this.waveCount++] ?? 0);
            this.dirty = true;
          }
        }
      }

      // scroll progress through the section drives the fold and the morph
      const p = clamp01((vh - rect.top) / (vh + rect.height));
      const fold = clamp01((p - 0.18) / 0.5);
      if (Math.abs(fold - this.foldT) > 0.002) {
        this.foldT = fold;
        this.dirty = true;
      }
      const morph = clamp01((p - 0.22) / 0.55);
      if (Math.abs(morph - this.morphScroll) > 0.002) {
        this.morphScroll = morph;
        this.dirty = true;
      }

      const delta = rect.top + rect.height / 2 - vh / 2;
      this.parY[0] = delta * PARALLAX[0];
      this.parY[1] = delta * PARALLAX[1];
      this.parY[2] = delta * PARALLAX[2];
      this.applyTransforms();
    }

    private applyTransforms(): void {
      if (reducedMotion) return;
      for (let d = 0; d < 3; d++) {
        const k = DRIFT_SCALE[d]!;
        const x = Math.round(this.driftX * k * 10) / 10;
        const y = Math.round((this.parY[d]! + this.driftY * k) * 10) / 10;
        this.layerEls[d]!.style.transform = `translate3d(${x}px, ${y}px, 0)`;
      }
    }

    /* -- loop ------------------------------------------------------ */

    private syncRunning(): void {
      if (reducedMotion) return; // one still frame; nothing to run
      const shouldRun = this.visible && !document.hidden;
      if (shouldRun && !this.running) {
        this.running = true;
        this.rafId = requestAnimationFrame(this.loop);
      } else if (!shouldRun && this.running) {
        this.running = false;
        cancelAnimationFrame(this.rafId);
      }
    }

    private loop = (t: number): void => {
      if (!this.running) return;
      const tick = Math.floor(t / PULSE);
      if (tick !== this.tick) {
        this.tick = tick; // stars breathe once per pulse
        this.dirty = true;
      }
      // the morph chases scroll, or the visitor's hand on Hermes
      const target = this.hermesHover ? 1 : this.morphScroll;
      const dm = target - this.morphCur;
      if (Math.abs(dm) > 0.002) {
        this.morphCur += Math.abs(dm) < 0.045 ? dm : Math.sign(dm) * 0.045;
        this.dirty = true;
      }
      // hover glow eases in and out
      for (const c of this.clusters) {
        const dh = c.hiTarget - c.hi;
        if (dh !== 0) {
          c.hi += Math.abs(dh) < 0.1 ? dh : Math.sign(dh) * 0.1;
          this.dirty = true;
        }
      }
      // keep frames coming while any reveal is still landing
      for (const c of this.clusters) {
        if (c.revealAt !== Infinity && t - c.revealAt < c.resolvedAt + BAR) {
          this.dirty = true;
          break;
        }
      }
      if (this.dirty) this.paint(t);
      this.rafId = requestAnimationFrame(this.loop);
    };

    /* -- painting -------------------------------------------------- */

    private paint(now: number): void {
      this.dirty = false;
      if (this.w === 0) return;
      for (const ctx of this.ctxs) {
        ctx.setTransform(this.dpr, 0, 0, this.dpr, 0, 0);
        ctx.clearRect(0, 0, this.w, this.h);
      }
      for (let i = 0; i < this.clusters.length; i++) {
        const c = this.clusters[i]!;
        const ctx = this.ctxs[c.def.depth]!;
        if (i === this.crossIdx) this.paintCross(ctx, c, now);
        else if (i === this.hermesIdx) this.paintHermes(ctx, c, now);
        else this.paintCluster(ctx, c, now);
      }
    }

    private drawStar(
      ctx: CanvasRenderingContext2D,
      x: number,
      y: number,
      r: number,
      alpha: number
    ): void {
      if (alpha <= 0.01 || r <= 0) return;
      ctx.globalAlpha = alpha * 0.16; // soft halo
      ctx.beginPath();
      ctx.arc(x, y, r * 3.2, 0, TAU);
      ctx.fill();
      ctx.globalAlpha = alpha;
      ctx.beginPath();
      ctx.arc(x, y, r, 0, TAU);
      ctx.fill();
      ctx.globalAlpha = alpha * 0.6; // 4-point sparkle
      ctx.lineWidth = 0.7;
      ctx.beginPath();
      ctx.moveTo(x - r * 2.6, y);
      ctx.lineTo(x + r * 2.6, y);
      ctx.moveTo(x, y - r * 2.6);
      ctx.lineTo(x, y + r * 2.6);
      ctx.stroke();
    }

    private paintCluster(ctx: CanvasRenderingContext2D, c: Cluster, now: number): void {
      const T = reducedMotion ? Infinity : now - c.revealAt;
      if (!(T > 0)) return;
      const boost = 1 + c.hi * 0.8;
      const lines = c.def.lines;
      ctx.strokeStyle = this.accentStyle;
      ctx.lineWidth = 1;
      if (T > c.resolvedAt) {
        this.strokeLineSet(ctx, lines, c.px, Math.min(1, 0.26 * boost));
      } else {
        for (let k = 0; k < lines.length; k++) {
          const lp = clamp01((T - LINE_START - c.lineDelays[k]!) / STAR_FADE);
          if (lp <= 0) continue;
          const l = lines[k]!;
          const x1 = c.px[l[0] * 2]!;
          const y1 = c.px[l[0] * 2 + 1]!;
          const x2 = c.px[l[1] * 2]!;
          const y2 = c.px[l[1] * 2 + 1]!;
          ctx.globalAlpha = Math.min(1, 0.26 * lp * boost);
          ctx.beginPath();
          ctx.moveTo(x1, y1);
          ctx.lineTo(x1 + (x2 - x1) * lp, y1 + (y2 - y1) * lp);
          ctx.stroke();
        }
      }
      ctx.fillStyle = this.accentStyle;
      const stars = c.def.stars;
      for (let j = 0; j < stars.length; j++) {
        const sp = reducedMotion ? 1 : clamp01((T - c.starDelays[j]!) / STAR_FADE);
        if (sp <= 0) continue;
        const s = stars[j]!;
        const tw = reducedMotion ? 1 : 0.82 + 0.18 * Math.sin(this.tick * 0.9 + j * 2.4 + c.def.cx);
        this.drawStar(
          ctx,
          c.px[j * 2]!,
          c.px[j * 2 + 1]!,
          (1.1 + 1.9 * s.w) * sp,
          Math.min(1, (0.35 + 0.55 * s.w) * sp * tw * boost)
        );
      }
      ctx.globalAlpha = 1;
    }

    private strokeLineSet(
      ctx: CanvasRenderingContext2D,
      lines: ReadonlyArray<ConLine>,
      px: Float32Array,
      alpha: number
    ): void {
      if (alpha <= 0.01) return;
      ctx.globalAlpha = alpha;
      ctx.beginPath();
      for (let k = 0; k < lines.length; k++) {
        const l = lines[k]!;
        ctx.moveTo(px[l[0] * 2]!, px[l[0] * 2 + 1]!);
        ctx.lineTo(px[l[1] * 2]!, px[l[1] * 2 + 1]!);
      }
      ctx.stroke();
    }

    /** Thoth → Hermes: lerped stars, crossfaded line sets. */
    private paintHermes(ctx: CanvasRenderingContext2D, c: Cluster, now: number): void {
      const T = reducedMotion ? Infinity : now - c.revealAt;
      if (!(T > 0)) return;
      const gate = reducedMotion ? 1 : clamp01((T - LINE_START) / BAR);
      const m = lingerEase(reducedMotion ? 1 : this.morphCur);
      if (m !== this.lastMorphDrawn) {
        for (let j = 0; j < this.hermesPx.length; j++) {
          this.hermesPx[j] = this.thothPx[j]! + (c.px[j]! - this.thothPx[j]!) * m;
        }
        this.lastMorphDrawn = m;
      }
      const boost = 1 + c.hi * 0.8;
      ctx.strokeStyle = this.accentStyle;
      ctx.lineWidth = 1;
      this.strokeLineSet(ctx, THOTH_FORM.lines, this.hermesPx, Math.min(1, 0.26 * (1 - m) * gate * boost));
      this.strokeLineSet(ctx, c.def.lines, this.hermesPx, Math.min(1, 0.26 * m * gate * boost));
      ctx.fillStyle = this.accentStyle;
      const stars = c.def.stars;
      for (let j = 0; j < stars.length; j++) {
        const sp = reducedMotion ? 1 : clamp01((T - c.starDelays[j]!) / STAR_FADE);
        if (sp <= 0) continue;
        const s = stars[j]!;
        const tw = reducedMotion ? 1 : 0.82 + 0.18 * Math.sin(this.tick * 0.9 + j * 2.4);
        this.drawStar(
          ctx,
          this.hermesPx[j * 2]!,
          this.hermesPx[j * 2 + 1]!,
          (1.1 + 1.9 * s.w) * sp,
          Math.min(1, (0.35 + 0.55 * s.w) * sp * tw * boost)
        );
      }
      ctx.globalAlpha = 1;
    }

    /** The Cross folding into the Black Cube, 2.5D-projected. */
    private paintCross(ctx: CanvasRenderingContext2D, c: Cluster, now: number): void {
      const T = reducedMotion ? Infinity : now - c.revealAt;
      if (!(T > 0)) return;
      const gate = reducedMotion ? 1 : clamp01(T / BAR);
      const t = reducedMotion ? 1 : this.foldT;
      if (t !== this.lastFoldDrawn) {
        foldCrossNet(t, this.crossBuf);
        this.projectCross(t);
        this.lastFoldDrawn = t;
      }
      // painter's order: farthest faces first
      const ord = this.crossOrder;
      for (let i = 1; i < 6; i++) {
        const v = ord[i]!;
        let j = i - 1;
        while (j >= 0 && this.crossZ[ord[j]!]! > this.crossZ[v]!) {
          ord[j + 1] = ord[j]!;
          j--;
        }
        ord[j + 1] = v;
      }
      const boost = 1 + c.hi * 0.8;
      for (let n = 0; n < 6; n++) {
        const f = ord[n]!;
        const base = f * 8;
        ctx.beginPath();
        ctx.moveTo(this.crossProj[base]!, this.crossProj[base + 1]!);
        for (let k = 1; k < 4; k++) {
          ctx.lineTo(this.crossProj[base + k * 2]!, this.crossProj[base + k * 2 + 1]!);
        }
        ctx.closePath();
        if (t > 0.01) {
          // the cube blackens as it closes
          ctx.fillStyle = this.voidStyle;
          ctx.globalAlpha = gate * t * 0.92;
          ctx.fill();
        }
        ctx.strokeStyle = this.accentStyle;
        ctx.lineWidth = 1;
        ctx.globalAlpha = Math.min(1, gate * (0.28 + 0.25 * t) * boost);
        ctx.stroke();
        ctx.fillStyle = this.accentStyle;
        for (let k = 0; k < 4; k++) {
          const j = f * 4 + k;
          const sp = reducedMotion ? 1 : clamp01((T - c.starDelays[j]!) / STAR_FADE);
          if (sp <= 0) continue;
          const tw = reducedMotion ? 1 : 0.85 + 0.15 * Math.sin(this.tick * 0.9 + j * 1.7);
          this.drawStar(
            ctx,
            this.crossProj[j * 2]!,
            this.crossProj[j * 2 + 1]!,
            1.6 * sp,
            Math.min(1, 0.7 * sp * tw * boost) * gate
          );
        }
      }
      ctx.globalAlpha = 1;
    }

    private projectCross(t: number): void {
      const c = this.clusters[this.crossIdx]!;
      const box = c.def.scale * Math.min(this.w, this.h);
      const scale = box / (4.15 - 2.55 * t); // net fills, cube fills
      const cx = (c.def.cx / 100) * this.w;
      const cy = (c.def.cy / 100) * this.h;
      const ax = -0.55 * t; // the flat net faces us; the solid turns away
      const ay = 0.62 * t;
      const cosX = Math.cos(ax);
      const sinX = Math.sin(ax);
      const cosY = Math.cos(ay);
      const sinY = Math.sin(ay);
      const F = 4; // camera distance, cube-side units
      for (let f = 0; f < 6; f++) {
        let zSum = 0;
        for (let k = 0; k < 4; k++) {
          const i = (f * 4 + k) * 3;
          const x0 = this.crossBuf[i]!;
          const y0 = this.crossBuf[i + 1]!;
          const z0 = this.crossBuf[i + 2]!;
          const x1 = x0 * cosY + z0 * sinY;
          const z1 = -x0 * sinY + z0 * cosY;
          const y1 = y0 * cosX - z1 * sinX;
          const z2 = y0 * sinX + z1 * cosX;
          const s = F / (F - z2);
          const o = (f * 4 + k) * 2;
          this.crossProj[o] = cx + x1 * s * scale;
          this.crossProj[o + 1] = cy + y1 * s * scale;
          zSum += z2;
        }
        this.crossZ[f] = zSum / 4;
      }
    }

    disconnectedCallback() {
      this.io?.disconnect();
      this.ro?.disconnect();
      window.removeEventListener('scroll', this.onScrollBound);
      document.removeEventListener('visibilitychange', this.onVisibility);
      this.removeEventListener('pointermove', this.onPointerMove);
      this.running = false;
      cancelAnimationFrame(this.rafId);
    }
  }

  if (!customElements.get('constellation-sky')) {
    customElements.define('constellation-sky', ConstellationSky);
  }
</script>
