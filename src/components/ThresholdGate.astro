---
/**
 * The Threshold — black screen, one dithered mark, one word.
 *
 * The Enter click wakes the audio engine: browser autoplay policy makes
 * a user gesture mandatory, so the site treats it as the visitor's first
 * offering. A silent path exists beside it. The gate shows once per
 * session; it never gates content, only atmosphere.
 */
import DitherCanvas from './DitherCanvas.astro';
---

<div class="threshold" id="threshold" data-open="true">
  <div class="threshold-mark">
    <DitherCanvas
      palette="greek"
      mode="static"
      cell={9}
      seed={77}
      accent="#b8cfe8"
      ratio="1 / 1"
      label=""
    />
  </div>
  <button class="threshold-enter term" id="threshold-enter">Enter.</button>
  <button class="threshold-silent" id="threshold-silent">enter in silence</button>
</div>

<style>
  .threshold {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    background: #000;
    transition: opacity var(--bar-7-8) var(--ease-veil), visibility 0s var(--bar-7-8);
  }
  .threshold[data-open='false'] {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }
  .threshold-mark {
    width: min(34vmin, 220px);
  }
  .threshold-enter {
    background: none;
    border: none;
    cursor: pointer;
    font-size: var(--text-lg);
    letter-spacing: var(--tracking-wide);
    color: var(--smoke-swan);
    padding: var(--space-1) var(--space-3);
  }
  .threshold-enter:hover {
    text-shadow: 0 0 18px var(--smoke-swan);
  }
  .threshold-silent {
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: rgba(232, 230, 225, 0.35);
    letter-spacing: var(--tracking-wide);
  }
  .threshold-silent:hover {
    color: rgba(232, 230, 225, 0.7);
  }
</style>

<script>
  import { wake, setMuted } from '../lib/audio/engine';

  const gate = document.getElementById('threshold');
  const SEEN = 'wilhelm.entered';

  function close() {
    gate?.setAttribute('data-open', 'false');
    document.body.style.removeProperty('overflow');
    try {
      sessionStorage.setItem(SEEN, '1');
    } catch {}
  }

  let alreadyIn = false;
  try {
    alreadyIn = sessionStorage.getItem(SEEN) === '1';
  } catch {}

  if (alreadyIn || window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    // returning within the session, or reduced motion: no ceremony
    gate?.setAttribute('data-open', 'false');
  } else {
    document.body.style.overflow = 'hidden';
    document.getElementById('threshold-enter')?.addEventListener('click', () => {
      void wake(); // the first offering
      close();
    });
    document.getElementById('threshold-silent')?.addEventListener('click', () => {
      setMuted(true);
      close();
    });
  }
</script>
